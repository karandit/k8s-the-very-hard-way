[Unit]
Description=Flannel Network Fabric
Documentation=https://github.com/flannel-io/flannel
After=network-online.target
Wants=network-online.target

[Service]
Type=notify

ExecStart=/usr/local/bin/flanneld \
  --ip-masq \
  --kube-subnet-mgr \
  --kube-api-url=https://control-plane:6443 \
  --kubeconfig-file=/etc/kubernetes/flannel.conf \
  --net-config-path=/etc/flannel/net-conf.json \
  --iface=eth1

# This is necessary for flannel to work correctly outside of the cluster
# Otherwise it complains about missing pod details
Environment="NODE_NAME=%H"

Restart=on-failure
RestartSec=3

NoNewPrivileges=true
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_RAW
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_RAW

[Install]
WantedBy=multi-user.target
